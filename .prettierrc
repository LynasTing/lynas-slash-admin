{
  "plugins": ["prettier-plugin-tailwindcss"],
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 140,
  "singleQuote": true,
  "trailingComma": "none",
  "semi": true,
  "htmlWhitespaceSensitivity": "ignore",
  "bracketSameLine": true,
  "arrowParens": "avoid",
  "endOfLine": "auto",
  "tailwindStylesheet": "./src/assets/style/global.css",
  "tailwindFunctions": ["cn", "clsx", "cva"]
}
